@model IEnumerable<CityHospitalManagement.Models.Admission>
@{
    ViewData["Title"] = "Admissions List";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white m-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-bed text-danger me-2"></i>Bed Admissions Log</h3>
            <p class="text-muted small m-0">Live hospital bed allocation tracking records.</p>
        </div>
        <a href="/Admissions/Create" class="btn btn-danger btn-md fw-bold rounded-pill shadow-sm"><i class="fa-solid fa-plus me-1"></i> New Admission</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light text-secondary small text-uppercase">
                <tr>
                    <th>Patient</th>
                    <th>Assigned Doctor</th>
                    <th>Ward</th>
                    <th class="text-center">Bed No.</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td><strong class="text-dark">@(item.Patient?.FullName ?? "N/A")</strong></td>
                            <td><span class="text-secondary">@(item.Doctor?.FullName ?? "N/A")</span></td>
                            <td><span class="badge bg-secondary-subtle text-dark">@item.WardType</span></td>
                            <td class="text-center"><code class="fw-bold text-danger">#@item.BedNumber</code></td>
                            <td>
                                @if (item.Status == "Active") {
                                    <span class="badge bg-success">Active Stay</span>
                                } else {
                                    <span class="badge bg-light text-muted border">Discharged</span>
                                }
                            </td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted small">No active admissions recorded.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>