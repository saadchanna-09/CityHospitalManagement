@model IEnumerable<CityHospitalManagement.Models.Doctor>
@{
    ViewData["Title"] = "Consultant Roster";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white m-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-user-doctor text-success me-2"></i>Active Consultant Rosters</h3>
            <p class="text-muted small m-0">Dynamic list logs for resource capacity allocation validation mapping rules.</p>
        </div>
        <a href="/Doctors/Create" class="btn btn-success btn-md fw-bold rounded-pill shadow-sm"><i class="fa-solid fa-plus me-1"></i> Register Consultant</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light text-secondary small text-uppercase">
                <tr>
                    <th>Consultant Identity</th>
                    <th>Clinical Domain Specialty</th>
                    <th>Assigned Ward Wing</th>
                    <th>Time Parameters Shift</th>
                    <th class="text-center">Dynamic Track Limit Capacity</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td><strong class="text-dark">@item.FullName</strong></td>
                            <td><span class="badge bg-primary-subtle text-primary px-2 py-1 fw-semibold">@item.Specialization</span></td>
                            <td><span class="text-dark fw-medium">@item.AssignedWard Ward</span></td>
                            <td><small class="text-secondary"><i class="fa-regular fa-clock me-1"></i>@item.ConsultationSchedule</small></td>
                            <td class="text-center"><span class="badge bg-dark px-3 text-white fw-bold">@item.MaxPatientCapacity Patients Max</span></td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted small">No consultants verified inside the local configuration database schema logs.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>