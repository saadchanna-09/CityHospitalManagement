@model IEnumerable<CityHospitalManagement.Models.Patient>
@{
    ViewData["Title"] = "Patients Registry";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white m-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-hospital-user text-primary me-2"></i>Patients Registry</h3>
            <p class="text-muted small m-0">Managed list of registered patients.</p>
        </div>
        <a href="/Patients/Create" class="btn btn-primary btn-md fw-bold rounded-pill shadow-sm"><i class="fa-solid fa-plus me-1"></i> Add New Patient</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light text-secondary small text-uppercase">
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Medical History</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td><strong class="text-dark">@item.FullName</strong></td>
                            <td><span class="text-secondary">@item.Email</span></td>
                            <td><code>@item.ContactNumber</code></td>
                            <td><span class="badge bg-light text-dark border">@item.MedicalHistory</span></td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted small">No patients registered yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>