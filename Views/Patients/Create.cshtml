@model CityHospitalManagement.Models.Patient
@{
    ViewData["Title"] = "Register Profile";
}

<div class="row justify-content-center my-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
            <h4 class="fw-bold text-dark mb-3"><i class="fa-solid fa-user-plus text-primary me-2"></i>Register Emergency/OPD Profile</h4>
            <hr />
            <form action="/Patients/Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Full Legal Identity Name</label>
                    <input name="FullName" class="form-control" placeholder="e.g., Muhammad Ali" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Secure Correspondence Email</label>
                    <input name="Email" type="email" class="form-control" placeholder="name@domain.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Contact Number</label>
                    <input name="ContactNumber" class="form-control" placeholder="e.g., 03331234567" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Medical History / Symptoms</label>
                    <textarea name="MedicalHistory" class="form-control" rows="3" placeholder="Symptoms or history notes..." required></textarea>
                </div>
                <div class="d-flex gap-2 justify-content-end pt-2">
                    <a href="/Patients" class="btn btn-light rounded-pill px-4 small">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">Save Patient</button>
                </div>
            </form>
        </div>
    </div>
</div>